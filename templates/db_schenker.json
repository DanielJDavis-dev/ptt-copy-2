{
  "name": "DB Schenker — PTT",
  "id": "db_schenker",
  "station_name": "DB SCHENKER",
  "description": "Application for permit to transfer containerized cargo — DB Schenker, Carson CA",
  "html_template": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<title>PTT — {{ mawb_full }}</title>\n<style>\n  @page { size: letter; margin: 15mm 16mm 12mm 16mm; }\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  body { font-family: Arial, Helvetica, sans-serif; font-size: 9.5pt; color: #000000; line-height: 1.4; }\n\n  .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }\n  .addr { font-size: 9.5pt; line-height: 1.5; }\n  .logo-wrap { text-align: right; }\n  .logo-row { display: flex; align-items: center; justify-content: flex-end; gap: 4px; margin-bottom: 2px; }\n  .logo-db { background: #000000; color: #fff; font-size: 16pt; font-weight: 900; padding: 1px 6px; border-radius: 1px; line-height: 1.1; }\n  .logo-name { font-size: 13pt; font-weight: 700; letter-spacing: 0.5px; }\n  .logo-tag { font-size: 7.5pt; font-weight: 700; margin-bottom: 3px; }\n  .logo-addr { font-size: 8.5pt; line-height: 1.4; }\n  .logo-links { font-size: 8pt; color: #000000; line-height: 1.3; }\n\n  .date-firms { display: flex; flex-direction: column; align-items: flex-end; gap: 5px; margin-bottom: 12px; }\n  .meta-line { font-size: 9.5pt; text-align: right; }\n  .meta-val { font-size: 11pt; font-weight: 700; padding-left: 5px; }\n\n  .re { font-weight: 700; font-size: 10pt; border-bottom: 1px solid #000000; padding-bottom: 5px; margin-bottom: 12px; }\n  .body-para { font-size: 9.5pt; text-align: justify; margin-bottom: 15px; }\n\n  .field-row { display: flex; align-items: flex-end; margin-bottom: 10px; width: 100%; }\n  .field-lbl { font-weight: 700; font-size: 9.5pt; white-space: nowrap; margin-right: 5px; }\n  .field-val { border-bottom: 1px solid #000000; flex: 1; font-size: 10.5pt; padding: 0 5px 1px; min-height: 18px; }\n  .inline-val { font-weight: 700; font-size: 11pt; border-bottom: 1px solid #000000; padding: 0 8px; }\n\n  .carrier-container { display: flex; gap: 15px; flex: 1; align-items: flex-end; }\n  .carrier-col { display: flex; flex-direction: column; align-items: center; }\n  .carrier-val { font-size: 11pt; font-weight: 700; text-align: center; border-bottom: 1px solid #000000; min-width: 60px; padding-bottom: 1px; }\n  .carrier-sub { font-size: 7.5pt; color: #333333; margin-top: 2px; text-transform: uppercase; }\n\n  .we-concur { text-align: center; font-weight: 700; font-size: 10pt; margin: 20px 0 5px; }\n  .sig-row { display: flex; justify-content: space-between; gap: 50px; margin-bottom: 15px; }\n  .sig-block { flex: 1; display: flex; flex-direction: column; }\n  .sig-line { border-bottom: 1px solid #000000; height: 30px; }\n  .sig-lbl { font-size: 8pt; color: #222222; margin-top: 4px; text-align: center; }\n  .approved { font-weight: 700; margin-top: 10px; font-size: 9.5pt; }\n  .approved-line { display: inline-block; border-bottom: 1px solid #000000; width: 220px; margin-left: 5px; height: 14px; }\n\n  .stars { text-align: center; font-size: 8pt; color: #000000; letter-spacing: 1.5px; margin: 12px 0; }\n\n  .tr-title { text-align: center; font-family: \"Times New Roman\", serif; font-size: 14pt; font-weight: 900; margin: 5px 0 10px; text-transform: uppercase; }\n  .delivered { font-size: 9.5pt; margin-bottom: 4px; line-height: 1.5; }\n  .delivered-name { font-size: 12pt; font-weight: 900; border-bottom: 1.5px solid #000000; padding: 0 4px; margin: 0 3px; display: inline-block; }\n  .cartman-lbl { font-size: 8pt; margin-left: 95px; }\n  .sig-right { display: flex; justify-content: flex-end; margin-top: 10px; }\n  .sig-right-block { width: 260px; }\n  .sig-right-line { border-bottom: 1px solid #000000; height: 30px; }\n  .sig-right-lbl { font-size: 8pt; text-align: center; margin-top: 4px; }\n\n  .received { font-size: 9.5pt; margin-top: 5px; }\n  .received-name { font-size: 12pt; font-weight: 900; text-decoration: underline; margin: 0 3px; }\n  .final-row { display: flex; justify-content: space-between; align-items: flex-end; margin-top: 20px; }\n  .final-date { font-size: 9.5pt; font-weight: 700; }\n  .final-date-line { display: inline-block; border-bottom: 1px solid #000000; width: 130px; margin-left: 3px; height: 14px; }\n  .final-sig { text-align: center; }\n  .final-sig-line { border-bottom: 1px solid #000000; width: 180px; display: inline-block; height: 30px; }\n  .final-sig-lbl { font-size: 8pt; margin-top: 4px; }\n\n  @media print {\n    body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }\n    .no-print { display: none; }\n  }\n</style>\n</head>\n<body>\n\n<div class=\"no-print\" style=\"text-align:right;margin-bottom:12px\">\n  <button onclick=\"window.print()\"\n    style=\"background:#000000;color:white;border:none;padding:8px 20px;\n           font-size:13px;font-weight:700;border-radius:3px;cursor:pointer\">\n    🖨️ Imprimir / Guardar como PDF\n  </button>\n  <p style=\"font-size:11px;color:#666;margin-top:4px\">\n    Ctrl+P &rarr; Destino: <b>Guardar como PDF</b> &rarr; Sin m&aacute;rgenes &rarr; Guardar\n  </p>\n</div>\n\n<!-- HEADER -->\n<div class=\"header\">\n  <div class=\"addr\">\n    Director, Airport Operations<br>\n    U.S Customs and Border Protection<br>\n    11099 S. La Cienega Blvd<br>\n    Los Angeles, CA 90045\n  </div>\n  <div class=\"logo-wrap\">\n    <div class=\"logo-row\">\n      <div class=\"logo-db\">DB</div>\n      <div class=\"logo-name\">SCHENKER</div>\n    </div>\n    <div class=\"logo-tag\">150 Years Elevating Lives</div>\n    <div class=\"logo-addr\">990 E. 233 St.<br>Carson, CA. 90745</div>\n    <div class=\"logo-links\">www.dbschenker.com<br>www.nowthatslogistics.com</div>\n  </div>\n</div>\n\n<!-- DATE + FIRMS -->\n<div class=\"date-firms\">\n  <div class=\"meta-line\">Date: <span class=\"meta-val\">{{ fecha }}</span></div>\n  <div class=\"meta-line\">Confirm Firms code <span class=\"meta-val\">{{ firms }}</span></div>\n</div>\n\n<!-- RE LINE -->\n<div class=\"re\">Re: &nbsp; Application for permit to transfer containerized cargo</div>\n\n<!-- BODY -->\n<p class=\"body-para\">\n  Application is made to transfer the Containers or Consolidations listed below from the airline&#8217;s premises\n  to DB Schenker Services Container Station at Los Angeles International Airport. An abstract of the aircraft\n  manifest showing the cargo referred to is attached to this application.\n</p>\n\n<!-- IMPORTING CARRIER -->\n<div class=\"field-row\">\n  <div class=\"field-lbl\">Importing Carrier:</div>\n  <div class=\"carrier-container\">\n    <div class=\"carrier-col\">\n      <div class=\"carrier-val\" style=\"width:60px\">{{ iata }}</div>\n      <div class=\"carrier-sub\">Name</div>\n    </div>\n    <div class=\"carrier-col\">\n      <div class=\"carrier-val\" style=\"width:80px\">{{ flight }}</div>\n      <div class=\"carrier-sub\">Flight</div>\n    </div>\n    <div class=\"carrier-col\">\n      <div class=\"carrier-val\" style=\"width:140px\">{{ aircraft_no }}</div>\n      <div class=\"carrier-sub\" style=\"align-self:flex-start\">Aircraft NO</div>\n    </div>\n  </div>\n</div>\n\n<!-- MAWB -->\n<div class=\"field-row\" style=\"margin-top:4px\">\n  <div class=\"field-lbl\">Master Air Waybill NO.</div>\n  <span class=\"inline-val\">{{ mawb_full }}</span>\n</div>\n\n<!-- PACKAGES + WEIGHT -->\n<div class=\"field-row\" style=\"margin-top:4px\">\n  <div class=\"field-lbl\">Total Number Units and/or Packages</div>\n  <span class=\"inline-val\" style=\"min-width:60px;text-align:center\">{{ packages }}</span>\n  <div class=\"field-lbl\" style=\"margin-left:30px\">Total Weight</div>\n  <span class=\"inline-val\" style=\"min-width:100px;text-align:center\">{{ weight }}</span>\n</div>\n\n<!-- WE CONCUR -->\n<div class=\"we-concur\">We Concur</div>\n<div class=\"sig-row\">\n  <div class=\"sig-block\">\n    <div class=\"sig-line\"></div>\n    <div class=\"sig-lbl\">Signature of authorized agent of container station</div>\n  </div>\n  <div class=\"sig-block\">\n    <div class=\"sig-line\"></div>\n    <div class=\"sig-lbl\">Signature of agent or Importing carrier</div>\n  </div>\n</div>\n<div class=\"approved\">Approved <span class=\"approved-line\"></span></div>\n\n<!-- DIVIDER -->\n<div class=\"stars\">*************************************************************************************</div>\n\n<!-- TRANSFER RECORD -->\n<div class=\"tr-title\">Transfer Record</div>\n<div class=\"delivered\">\n  Delivered to: <span class=\"delivered-name\">DB SCHENKER</span>\n  &nbsp; in apparent good order and condition except as noted: &nbsp; TFS\n</div>\n<div class=\"cartman-lbl\">Cartman, C.H.L. No/or container trucker</div>\n<div class=\"sig-right\">\n  <div class=\"sig-right-block\">\n    <div class=\"sig-right-line\"></div>\n    <div class=\"sig-right-lbl\">Signature of cartman or trucker</div>\n  </div>\n</div>\n\n<!-- DIVIDER -->\n<div class=\"stars\">*************************************************************************************</div>\n\n<!-- RECEIVED -->\n<div class=\"received\">\n  Received at <span class=\"received-name\">DB SCHENKER</span> Container Station\n</div>\n<div class=\"final-row\">\n  <div class=\"final-date\">Date: <span class=\"final-date-line\"></span></div>\n  <div class=\"final-sig\">\n    <div class=\"final-sig-line\"></div>\n    <div class=\"final-sig-lbl\">Signature of container customs Inspector</div>\n  </div>\n  <div class=\"final-sig\">\n    <div class=\"final-sig-line\"></div>\n    <div class=\"final-sig-lbl\">Signature of agent at container station</div>\n  </div>\n</div>\n\n</body>\n</html>"
}